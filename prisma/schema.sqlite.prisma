// AgentTrace — Prisma schema (SQLite profile)
// Same data model as prisma/schema.prisma, for a 100% local dev setup
// with zero external database dependency (no Docker, no hosted Postgres).
//
// Activate this profile with:
//   bun run db:generate:sqlite && bun run db:push:sqlite
//   cp src/lib/db.sqlite.ts.example src/lib/db.ts   (see file for details)
//   DATABASE_URL="file:./dev.db" in .env
//
// Keep in sync with prisma/schema.prisma if the data model changes.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma-sqlite"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs        Run[]
  apiKeys     ApiKey[]

  @@index([userId])
}

model Run {
  id        String      @id @default(cuid())
  projectId String
  name      String
  status    String      @default("running") // running | completed | failed
  startedAt DateTime    @default(now())
  endedAt   DateTime?
  metadata  String?
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events    Event[]

  @@index([projectId])
  @@index([status])
}

model Event {
  id          String   @id @default(cuid())
  runId       String
  timestamp   DateTime @default(now())
  seq         Int      @default(0)
  source      String
  target      String
  type        String // llm_call | tool_call | tool_result | handoff | error | final_answer
  label       String?
  payload     String   // JSON string
  durationMs  Int?
  status      String   @default("ok") // ok | error | pending
  run         Run      @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([runId, seq])
}

model ApiKey {
  id        String   @id @default(cuid())
  projectId String
  keyHash   String   @unique
  prefix    String   // first 8 chars for display
  label     String?
  createdAt DateTime @default(now())
  lastUsedAt DateTime?
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
