# AgentTrace — .dockerignore
# Keep build context lean so Docker cache + build are fast.

# deps & build artifacts
node_modules
.next
out
dist
build

# logs & local state
*.log
dev.log
server.log
socket-service.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local database (mounted as a volume in compose)
db
*.db
*.db-journal

# editor / OS
.git
.gitignore
.github
.vscode
.idea
.DS_Store
*.swp

# docs & examples (not needed in the image)
README.md
docs
examples

# docker
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.*.yml

# misc
.env*.local
.env
worklog.md
agent-ctx
